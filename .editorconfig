root = true

[*]
charset = utf-8-bom
end_of_line = crlf
trim_trailing_whitespace = false
insert_final_newline = false

[**.cs]
indent_style = space
indent_size = 4
tab_width = 4

# Disable all warnings in external code
[{Library/PackageCache,Packages,Assets/{Packages,Plugins}}/**.cs]
# Generated from: https://www.jetbrains.com/help/resharper/Reference__Code_Inspections_CSHARP.html
# Code Notification (3 inspections)
resharper_c_sharp14_overload_resolution_with_span_breaking_change_highlighting = none # CSharp14OverloadResolutionWithSpanBreakingChange, C# 14 breaking change in overload resolution with span parameters
resharper_invocation_is_skipped_highlighting = none # InvocationIsSkipped, Method invocation is skipped
resharper_non_parsable_element_highlighting = none # NonParsableElement, Part of the code cannot be parsed

